pipeline {
   agent {
       docker {
           image 'lachlanevenson/k8s-kubectl:v1.25.0'
           args '--entrypoint ""'
       }
   }
   stages {
       stage('Check kubectl') {
           steps {
               withCredentials([file(credentialsId: 'kubeconfig-minikube', variable: 'KUBECONFIG')]) {
                   sh 'kubectl version --client'
                   sh 'kubectl get pods'
               }
           }
       }
       stage('Deploy to k8s') {
           steps {
               withCredentials([file(credentialsId: 'kubeconfig-minikube', variable: 'KUBECONFIG')]) {
                   sh "sed -i 's/IMAGE_TAG/${BUILD_NUMBER}/g' module6/deployment.yml"
                   sh 'kubectl apply -f module6/deployment.yml'
               }
           }
       }
   }
}
